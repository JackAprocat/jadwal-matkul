<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgScreen">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Back"
                android:tint="@color/colorAccent"/>

            <TextView
                android:id="@+id/tvKelas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jadwal 1AKA"
                android:textColor="@color/colorTextPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

            <ImageButton
                android:id="@+id/btnToggleCompact"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Toggle Compact"
                android:tint="@color/colorAccent"/>
        </LinearLayout>

        <!-- Tombol Hari -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:id="@+id/layoutHari"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"/>
        </HorizontalScrollView>

        <!-- Mode Tampilan Ringkas -->
        <TextView
            android:id="@+id/tvModeRingkas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode Tampilan Ringkas"
            android:textColor="@color/colorAccent"
            android:textSize="13sp"
            android:textStyle="italic"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:background="?attr/selectableItemBackground"/>

        <!-- Judul Jadwal Hari -->
        <TextView
            android:id="@+id/tvJudulHari"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jadwal SENIN"
            android:textColor="@color/colorAccent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="8dp"/>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!-- List Jadwal -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <!-- Kosong -->
        <TextView
            android:id="@+id/tvKosong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tidak ada jadwal 🎉"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="@color/colorTextHint"
            android:padding="32dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- FAB: Refresh -->
    <ImageButton
        android:id="@+id/fabRefresh"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="84dp"
        android:background="@drawable/bg_fab"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="Refresh"
        android:tint="@color/black"
        android:elevation="6dp"/>

    <!-- FAB: Compact Toggle -->
    <ImageButton
        android:id="@+id/fabCompact"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_fab"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:contentDescription="Compact View"
        android:tint="@color/black"
        android:elevation="6dp"/>

</FrameLayout>