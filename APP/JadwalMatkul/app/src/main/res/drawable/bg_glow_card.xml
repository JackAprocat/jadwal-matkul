<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp"/>
            <solid android:color="#338C52FF"/>
        </shape>
    </item>

    <!-- Inner Glow -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#668C52FF"/>
        </shape>
    </item>

    <!-- Solid Dark Card with Thin Bright Stroke -->
    <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="@color/colorBgKelasCard"/>
            <stroke android:width="1dp" android:color="#8C52FF"/>
        </shape>
    </item>
</layer-list>
